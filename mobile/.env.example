# Base URL of the FastAPI backend, as reachable FROM YOUR DEVICE.
#
# - iOS simulator / web on the same machine: http://localhost:8000
# - A physical phone (dev client): use your computer's LAN IP, e.g.
#     EXPO_PUBLIC_API_URL=http://192.168.1.20:8000
#   (find it on Windows with `ipconfig` -> IPv4 Address). Phone and PC must be
#   on the same Wi-Fi, and the backend must be started so it listens on your LAN.
#
# EXPO_PUBLIC_ vars are inlined at bundle time by Expo. Copy this file to .env.
EXPO_PUBLIC_API_URL=http://localhost:8000
