# Copy this file to .env and fill in your real values. NEVER commit .env.

# --- OpenAI (shared by both languages) ---
OPENAI_API_KEY=
CHAT_MODEL=gpt-4o-mini

# =============================================================================
# Retrieval is split across TWO Pinecone accounts, to use each account's free
# 2GB tier instead of paying for Pinecone Standard. Hindi and English therefore
# have their OWN api key + index AND their OWN embedding model/dimension. A query
# must pair the right model with the right index; mixing them (e.g. embedding an
# English question with the 3072-dim Hindi model) fails with a dimension mismatch.
# =============================================================================

# --- Hindi retrieval (original Pinecone account) ---
# Default namespace; ~75k Hindi vectors. Embedded with text-embedding-3-large
# (3072-dim). EMBEDDING_MODEL MUST match how this index was ingested.
PINECONE_API_KEY=
PINECONE_INDEX=
EMBEDDING_MODEL=text-embedding-3-large

# --- English retrieval (separate Pinecone account) ---
# Default namespace of index "askthymonk-en-large". Embedded with
# text-embedding-3-large (3072-dim) — chosen over -small because it grounds
# reliably at top_k=3 (see TOP_K_EN below). EMBEDDING_MODEL_EN MUST match the
# model the index was built with. (Same env-var names as the ingestion side.)
PINECONE_API_KEY_EN=
PINECONE_INDEX_EN=askthymonk-en-large
EMBEDDING_MODEL_EN=text-embedding-3-large

# --- App behavior ---
# Which languages the app may offer. JSON array or comma-separated. Both "hi"
# (default namespace) and "en" (en namespace) now have data in the index.
SUPPORTED_LANGUAGES=["hi","en"]

# Comma-separated allowed CORS origins, or * for all (fine for local dev).
CORS_ORIGINS=*

# Per-IP rate limit for /api/wisdom (slowapi syntax).
RATE_LIMIT=20/minute

# Optional shared secret. When set (non-empty), /api/wisdom rejects requests
# whose X-API-Key header doesn't match. Leave empty for local dev. Set the SAME
# value here and in mobile/.env (EXPO_PUBLIC_API_KEY) before deploying so the
# public URL can't be hit directly. NOTE: a value shipped in a public mobile app
# is extractable, so this deters casual/direct hits but is not strong auth.
API_SHARED_SECRET=

# Chunks retrieved per query, per language. Both use 3: with text-embedding-3-
# large, English grounds reliably at top_k=3 (an earlier -small index needed 6).
TOP_K=3
TOP_K_EN=3
